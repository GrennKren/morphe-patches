# Auto detect text files and perform LF normalization
* text=auto

# Source code files - force LF on checkout
*.java text eol=lf
*.kt text eol=lf
*.kts text eol=lf
*.xml text eol=lf
*.json text eol=lf
*.properties text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.js text eol=lf
*.ts text eol=lf
*.html text eol=lf
*.css text eol=lf
*.gradle text eol=lf

# Shell scripts - must use LF
*.sh text eol=lf
gradlew text eol=lf

# Windows scripts - must use CRLF
*.bat text eol=crlf
gradlew.bat text eol=crlf

# Binary files - don't touch
*.apk binary
*.jar binary
*.png binary
*.jpg binary
*.gif binary
*.ico binary
*.zip binary